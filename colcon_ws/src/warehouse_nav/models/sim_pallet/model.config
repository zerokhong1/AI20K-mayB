<?xml version="1.0"?>
<model>
  <name>sim_pallet</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <author>
    <name>AI20K</name>
  </author>
  <description>
    Small dynamic pallet liftable by the warehouse_forklift fork.
    Deck 0.40x0.40x0.04 at z=0.12 (bottom z=0.10, 1 cm above fork top 0.09).
    Four legs 0.05x0.05x0.10; fork channel 0.30 m between inner leg faces.
    Mass 8 kg. Model origin at ground level (leg bottoms flush with z=0).
  </description>
</model>
