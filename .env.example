# Copy này sang .env (không commit .env — đã gitignore)
# Chọn 1 trong 2 provider; comment out provider còn lại.

# ── Provider A: Gemini flash-lite (remote, cần key) ─────────────────────────
# GEMINI_API_KEY=your-key-here          # key riêng, KHÔNG dùng chung key P0.1
# LLM_PROVIDER=gemini                   # mặc định nếu không set
# GEMINI_MODEL=gemini-flash-lite-latest # override nếu API region cần string khác

# ── Provider B: Ollama local (không cần key) ────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434  # mặc định; đổi nếu Ollama chạy port khác

# ── Backend ─────────────────────────────────────────────────────────────────
# WORLD_BACKEND=flat2d    # default; offline, không cần ROS
# WORLD_BACKEND=gazebo    # cần Gazebo stack: bash scripts/start_demo.sh
